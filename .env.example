# ── LLM (required for narration & randomizer) ────────────────────────────────
HF_TOKEN=hf_your_token_here

# ── Vector store ─────────────────────────────────────────────────────────────
# VECTOR_DB_TYPE: "chroma" (default) or "qdrant"
VECTOR_DB_TYPE=chroma

# VECTOR_DB_URL: omit for in-process Chroma (no Docker needed in dev).
# Set to the container URL when using Docker Compose.
#   Chroma server:  VECTOR_DB_URL=http://localhost:8001
#   Qdrant server:  VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_URL=

# VECTOR_DB_PATH: local persistence directory for in-process Chroma.
# Ignored when VECTOR_DB_URL is set or VECTOR_DB_TYPE=qdrant.
VECTOR_DB_PATH=./data/chroma
